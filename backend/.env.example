# ============================================================
# MediCare+ — Copiez ce fichier en ".env" (backend/.env)
# Ne commitez JAMAIS .env sur GitHub
# ============================================================

# --- LOCAL (PC + Workbench, base Pharmacie_Garde) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=Pharmacie_Garde
PORT=3000
JWT_SECRET=changez_moi_en_production

# Connexion Google (espace utilisateur) — Google Cloud → Clients → ID client OAuth (Web)
# Origines JavaScript : http://localhost:3000
# URI de redirection autorisées : http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optionnel (prod) : https://votre-domaine.com
PUBLIC_APP_URL=http://localhost:3000
# Local Windows si erreur « fetch failed » / certificat : GOOGLE_OAUTH_RELAX_TLS=1
# Ne pas activer en production (laisser vide ou =0)
GOOGLE_OAUTH_RELAX_TLS=1

# --- RAILWAY (cloud) : utilisez plutôt les Variables Railway ---
# Ne mettez pas tout ça dans .env sur GitHub ; configurez sur railway.app
# DB_NAME=railway
# DB_SSL=true
# DATABASE_URL=mysql://user:pass@host:port/railway

# Développement : lien reset mot de passe affiché dans l'API (pas d'email)
DEV_RESET_LINK=1
